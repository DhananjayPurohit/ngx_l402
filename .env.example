# ─────────────────────────────────────────────────────────────────────────────
# ngx_l402 — Environment Variables Reference
#
# Copy this file to .env (or export the relevant vars into nginx.service /
# docker-compose.yml).  Lines starting with # are comments.
#
# REQUIRED vs OPTIONAL:
#   Lines marked [REQUIRED] must be set for the module to start correctly.
#   Lines marked [OPTIONAL] have safe defaults and can be omitted.
# ─────────────────────────────────────────────────────────────────────────────


# ── Core ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Macaroon signing key — generate with: openssl rand -hex 32
# WARNING: Changing this invalidates all previously issued macaroons.
ROOT_KEY=change-me-generate-with-openssl-rand-hex-32

# [REQUIRED] Lightning backend. One of: LND | CLN | LNURL | NWC | BOLT12 | ECLAIR
LN_CLIENT_TYPE=LNURL


# ── LNURL backend ─────────────────────────────────────────────────────────────

# [REQUIRED for LN_CLIENT_TYPE=LNURL]
LNURL_ADDRESS=username@your-lnurl-server.com


# ── LND (direct gRPC) ─────────────────────────────────────────────────────────

# [REQUIRED for LN_CLIENT_TYPE=LND, non-LNC mode]
# LND_ADDRESS=localhost:10009
# MACAROON_FILE_PATH=/path/to/admin.macaroon
# CERT_FILE_PATH=/path/to/tls.cert

# [OPTIONAL] Route LND gRPC through a SOCKS5 proxy (e.g. Tor)
# SOCKS5_PROXY=socks5://127.0.0.1:9050


# ── LND via Lightning Node Connect (LNC) ──────────────────────────────────────

# [REQUIRED for LNC mode — also set LN_CLIENT_TYPE=LND]
# LNC_PAIRING_PHRASE="word1 word2 word3 ... word10"
# LNC_MAILBOX_SERVER=mailbox.terminal.lightning.today:443


# ── CLN (Core Lightning) ──────────────────────────────────────────────────────

# [REQUIRED for LN_CLIENT_TYPE=CLN or BOLT12]
# CLN_LIGHTNING_RPC_FILE_PATH=/root/.lightning/bitcoin/lightning-rpc

# [REQUIRED for LN_CLIENT_TYPE=BOLT12]
# BOLT12_OFFER=lno1...
# Note: BOLT12 mode connects to your CLN node via CLN_LIGHTNING_RPC_FILE_PATH
# and calls fetchinvoice to derive a fresh BOLT11 invoice from the reusable
# BOLT12 offer. Both BOLT12_OFFER and CLN_LIGHTNING_RPC_FILE_PATH are required.


# ── NWC (Nostr Wallet Connect) ────────────────────────────────────────────────

# [REQUIRED for LN_CLIENT_TYPE=NWC]
# NWC_URI=nostr+walletconnect://<pubkey>?relay=<relay_url>&secret=<secret>


# ── Eclair ────────────────────────────────────────────────────────────────────

# [REQUIRED for LN_CLIENT_TYPE=ECLAIR]
# ECLAIR_ADDRESS=http://127.0.0.1:8282
# ECLAIR_PASSWORD=your-eclair-api-password
# Note: ECLAIR_PASSWORD has NO default. If unset, auto-detect is disabled and
#       a startup error is logged. There is no fallback credential.


# ── Redis (replay protection & dynamic pricing) ───────────────────────────────

# [STRONGLY RECOMMENDED in production]
# Without Redis, replay protection falls back to in-process cache only
# (single-worker, lost on restart). Multi-worker deployments REQUIRE Redis.
REDIS_URL=redis://127.0.0.1:6379

# [OPTIONAL] Redis connection pool size (default: 4)
# REDIS_POOL_SIZE=4

# [OPTIONAL] TTL for spent Lightning preimages (default: 86400 = 24 h)
# Set to 2147483647 (~68 years) for permanent replay protection.
# Do NOT set to 0 — Redis rejects EX 0 and the module will fail-open.
# L402_PREIMAGE_TTL_SECONDS=86400

# [OPTIONAL] TTL for spent Cashu tokens (default: 86400 = 24 h)
# Set to 2147483647 (~68 years) for permanent replay protection.
# Do NOT set to 0 — Redis rejects EX 0 and the module will fail-open.
# L402_CASHU_TOKEN_TTL_SECONDS=86400


# ── Cashu eCash ───────────────────────────────────────────────────────────────

# [OPTIONAL] Enable Cashu ecash payment acceptance (default: false)
# CASHU_ECASH_SUPPORT=false

# [REQUIRED if CASHU_ECASH_SUPPORT=true] Path to SQLite CDK wallet database
# CASHU_DB_PATH=/var/lib/nginx/cashu_tokens.db

# [REQUIRED if CASHU_ECASH_SUPPORT=true] BIP39 wallet mnemonic (the Cashu/NUT-13
# backup phrase). 12 or 24 English words. This is the ONLY backup of your wallet
# — anyone with it can steal your Cashu tokens, and losing it loses the funds.
# Leave unset to have one generated and saved next to the DB on first run (watch
# the logs for the phrase). For a wallet shared with paygress, set the SAME phrase.
# CASHU_WALLET_MNEMONIC="word1 word2 ... word12"
# [OPTIONAL] Where to persist a generated mnemonic (defaults beside the DB file).
# CASHU_WALLET_MNEMONIC_FILE=/var/lib/nginx/wallet.mnemonic

# [OPTIONAL] Comma-separated mint URLs to whitelist (scheme+host are case-insensitive).
# Standard mode: if unset, all mints are accepted.
# P2PK mode: REQUIRED — used to issue NUT-24 payment requests.
# CASHU_WHITELISTED_MINTS=https://mint.minibits.cash,https://mint2.example.com

# [OPTIONAL] Automatically melt received Cashu tokens back to Lightning
# CASHU_REDEEM_ON_LIGHTNING=false
# CASHU_REDEMPTION_INTERVAL_SECS=3600

# Redemption fee tuning (all optional):
# CASHU_MELT_MIN_BALANCE_SATS=10        # min wallet balance before melting (default: 10)
# CASHU_MELT_FEE_RESERVE_PERCENT=1      # % of amount to reserve for fees (default: 1)
# CASHU_MELT_MIN_FEE_RESERVE_SATS=4     # floor for fee reserve in sats (default: 4)
# CASHU_MAX_PROOFS_PER_MELT=0           # max proofs per melt cycle; 0 = unlimited


# ── Cashu P2PK mode ───────────────────────────────────────────────────────────

# [OPTIONAL] Enable NUT-24 P2PK locked tokens (default: false)
# P2PK prevents mint-side replay; CASHU_WHITELISTED_MINTS is required alongside it.
# CASHU_P2PK_MODE=false

# [REQUIRED if CASHU_P2PK_MODE=true] secp256k1 private key, 32 bytes hex
# WARNING: Anyone with this key can spend tokens locked to your public key.
# Generate with: openssl rand -hex 32 — never commit to Git.
# CASHU_P2PK_PRIVATE_KEY=change-me-generate-with-openssl-rand-hex-32


# ── Capability manifest (/.well-known/l402-services) ──────────────────────────

# All optional — unset fields are omitted from the manifest JSON response.
# L402_SERVICE_NAME=My API
# L402_SERVICE_DESCRIPTION=Premium data, paid per request.
# L402_SERVICE_OPERATOR=npub1...    # Nostr pubkey, DID, or free-form identifier
# L402_SERVICE_CONTACT=ops@example.com


# ── Logging ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Rust log filter (default: info)
RUST_LOG=info
# For verbose module-level logs:
# RUST_LOG=ngx_l402_lib=debug,info

# [OPTIONAL] Log per-request performance timing (set to any non-empty value to enable)
# L402_PERF_LOG=1

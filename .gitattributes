# Keep source and config files as LF in the repository, regardless of a
# contributor's core.autocrlf setting. Prevents Windows checkouts from
# committing CRLF and producing whole-file diffs/merge conflicts.
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.conf  text eol=lf
*.json  text eol=lf
